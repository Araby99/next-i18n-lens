{
  "name": "next-i18n-lens",
  "version": "0.1.3",
  "description": "A local-first, zero-dependency visual translation studio for Next.js (App Router) and React.",
  "license": "MIT",
  "author": "Araby99",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Araby99/next-i18n-lens.git"
  },
  "bugs": {
    "url": "https://github.com/Araby99/next-i18n-lens/issues"
  },
  "homepage": "https://github.com/Araby99/next-i18n-lens#readme",
  "keywords": [
    "nextjs",
    "react",
    "i18n",
    "internationalization",
    "translation",
    "studio",
    "visual-editor",
    "localization",
    "in-context-editing",
    "zero-dependency"
  ],
  "type": "module",
  "main": "./dist/server/index.js",
  "bin": {
    "next-i18n-lens": "dist/codemod/index.js"
  },
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run studio:build",
    "studio:dev": "vite src/studio --config src/studio/vite.config.ts",
    "studio:build": "vite build src/studio --config src/studio/vite.config.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.19",
    "clsx": "^2.1.1",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vite": "^8.0.14",
    "vitest": "^1.6.0"
  }
}